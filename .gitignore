# Python bytecode (the MCP shim is interpreted; caches are build artifacts)
__pycache__/
*.pyc

# Nix build symlinks (from `nix build` on the nix/ test toolchain)
result
result-*

# Agent scaffolding (machine-local, generated by agent-scaffold at SessionStart)
.model/

# Project memory (memd) — ship the skeleton, not the contents
.memory/*.md
.memory/archive/*.md
.memory/inbox/*
!.memory/inbox/.gitkeep
